# =========================
# SERVER
# =========================
PORT=5000

# =========================
# DATABASE
# =========================
# MongoDB Atlas connection string. Get this from Atlas → Connect → Drivers.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

# =========================
# JWT
# =========================
# Generate with: openssl rand -base64 48
JWT_SECRET=

# =========================
# FIREBASE ADMIN SDK
# =========================
# From Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# =========================
# CLOUDINARY (product image uploads)
# =========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =========================
# MTN MOMO RWANDA
# =========================
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_ENVIRONMENT=sandbox

# =========================
# GOOGLE MAPS
# =========================
# Distance Matrix API — used for delivery fee calculation
GOOGLE_MAPS_API_KEY=

# =========================
# FIREBASE CLOUD MESSAGING
# =========================
FCM_SERVER_KEY=

# =========================
# STORE LOCATION
# =========================
# Origin used for delivery distance calculations
STORE_ORIGIN_ADDRESS="Murambi Cell, Gatenga Sector, Kicukiro District, Kigali, Rwanda"

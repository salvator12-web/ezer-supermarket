# Copy to .env and fill in real values. Never commit .env.

# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# Firebase client config (staff login only — customers never see this)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Web Push certificate key pair (Firebase console → Project settings → Cloud
# Messaging → Web Push certificates). Needed for rider FCM push registration.
VITE_FIREBASE_VAPID_KEY=
